{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/myheart521/WAMProbe/release/evidence-manifest-v0.1.schema.json",
  "title": "WAMProbe release evidence manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_version",
    "committed_evidence",
    "external_evidence"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "release_version": {"type": "string", "minLength": 1},
    "committed_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "external_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "kind",
          "sha256",
          "location",
          "availability",
          "reason_not_committed"
        ],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "location": {"type": "string", "minLength": 1},
          "availability": {"enum": ["local-only", "release-bundle-pending"]},
          "reason_not_committed": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
