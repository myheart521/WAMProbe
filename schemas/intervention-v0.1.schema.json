{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/myheart521/WAMProbe/schemas/intervention-v0.1.schema.json",
  "title": "WAMProbe 2D intervention suite v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "benchmark_id", "groups"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["context_id", "position", "goal", "actions"],
        "properties": {
          "context_id": {"type": "string", "minLength": 1},
          "position": {"$ref": "#/$defs/vec2"},
          "goal": {"$ref": "#/$defs/vec2"},
          "actions": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["name", "delta"],
              "properties": {
                "name": {"type": "string", "minLength": 1},
                "delta": {"$ref": "#/$defs/vec2"}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "vec2": {
      "type": "array",
      "prefixItems": [{"type": "number"}, {"type": "number"}],
      "items": false
    }
  }
}
